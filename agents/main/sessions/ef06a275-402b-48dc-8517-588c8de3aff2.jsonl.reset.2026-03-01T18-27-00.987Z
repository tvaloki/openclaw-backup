{"type":"message","id":"8ed8aa8a","parentId":"6386c526","timestamp":"2026-03-01T14:34:23.375Z","message":{"role":"toolResult","toolCallId":"call_gv4T6QvG6EUxXJzAf2FkbfK6","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\nsource \"$HOME/.bashrc\" >/dev/null 2>&1 || true\n\nMSG=$(python3 /home/ec2-user/.openclaw/workspace/tools/important_email_digest.py)\n\nopenclaw message send \\\n  --channel telegram \\\n  --target 8268094294 \\\n  --message \"$MSG\" >/dev/null\n\necho \"[$(date -u +%FT%TZ)] sent important-email digest\" >> /home/ec2-user/.openclaw/workspace/knowledge/email-vault/99_Admin/important-digest.log"}],"details":{"status":"completed","exitCode":0,"durationMs":428,"aggregated":"#!/usr/bin/env bash\nset -euo pipefail\nsource \"$HOME/.bashrc\" >/dev/null 2>&1 || true\n\nMSG=$(python3 /home/ec2-user/.openclaw/workspace/tools/important_email_digest.py)\n\nopenclaw message send \\\n  --channel telegram \\\n  --target 8268094294 \\\n  --message \"$MSG\" >/dev/null\n\necho \"[$(date -u +%FT%TZ)] sent important-email digest\" >> /home/ec2-user/.openclaw/workspace/knowledge/email-vault/99_Admin/important-digest.log","cwd":"/home/ec2-user/.openclaw/workspace"},"isError":false,"timestamp":1772375663372}}
{"type":"message","id":"0a3cc8a7","parentId":"8ed8aa8a","timestamp":"2026-03-01T14:34:23.694Z","message":{"role":"toolResult","toolCallId":"call_f7bdjyqAIJk6qAhdXFwQivGq","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env bash\nset -euo pipefail\nsource /home/ec2-user/.openclaw/workspace/tools/calendar_pull.env\n\nICS_DIR=/home/ec2-user/.openclaw/workspace/data/calendar\nOUT_MD=/home/ec2-user/.openclaw/workspace/knowledge/calendar/daily-brief.md\nICS_FILE=\"$ICS_DIR/outlook-latest.ics\"\n\nmkdir -p \"$ICS_DIR\" /home/ec2-user/.openclaw/workspace/knowledge/calendar\n\ncurl -fsSL \"$OUTLOOK_ICS_URL\" -o \"$ICS_FILE\"\n\nTODAY_LOCAL=$(TZ=America/Chicago date +%F)\npython3 /home/ec2-user/.openclaw/workspace/tools/parse_calendar_ics.py \"$ICS_FILE\" --date \"$TODAY_LOCAL\" --out \"$OUT_MD\" >/dev/null\n\nMSG=$(cat \"$OUT_MD\")\nopenclaw message send --channel telegram --target 8268094294 --message \"$MSG\" >/dev/null\n\necho \"[$(date -u +%FT%TZ)] sent calendar brief for $TODAY_LOCAL\" >> /home/ec2-user/.openclaw/workspace/knowledge/calendar/calendar-brief.log"}],"details":{"status":"completed","exitCode":0,"durationMs":312,"aggregated":"#!/usr/bin/env bash\nset -euo pipefail\nsource /home/ec2-user/.openclaw/workspace/tools/calendar_pull.env\n\nICS_DIR=/home/ec2-user/.openclaw/workspace/data/calendar\nOUT_MD=/home/ec2-user/.openclaw/workspace/knowledge/calendar/daily-brief.md\nICS_FILE=\"$ICS_DIR/outlook-latest.ics\"\n\nmkdir -p \"$ICS_DIR\" /home/ec2-user/.openclaw/workspace/knowledge/calendar\n\ncurl -fsSL \"$OUTLOOK_ICS_URL\" -o \"$ICS_FILE\"\n\nTODAY_LOCAL=$(TZ=America/Chicago date +%F)\npython3 /home/ec2-user/.openclaw/workspace/tools/parse_calendar_ics.py \"$ICS_FILE\" --date \"$TODAY_LOCAL\" --out \"$OUT_MD\" >/dev/null\n\nMSG=$(cat \"$OUT_MD\")\nopenclaw message send --channel telegram --target 8268094294 --message \"$MSG\" >/dev/null\n\necho \"[$(date -u +%FT%TZ)] sent calendar brief for $TODAY_LOCAL\" >> /home/ec2-user/.openclaw/workspace/knowledge/calendar/calendar-brief.log","cwd":"/home/ec2-user/.openclaw/workspace"},"isError":false,"timestamp":1772375663691}}
{"type":"message","id":"64e31a41","parentId":"0a3cc8a7","timestamp":"2026-03-01T14:34:24.015Z","message":{"role":"toolResult","toolCallId":"call_Z0RYBMrVIuD7o2jz3tv8B5yw","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\nimport os, imaplib, email\nfrom email.header import decode_header\nfrom datetime import datetime, timedelta\nfrom collections import Counter\nimport smtplib\nfrom email.message import EmailMessage\n\n# Optional env file loader (KEY='value' lines)\nenv_file = '/home/ec2-user/.openclaw/workspace/tools/icloud_mail.env'\nif os.path.exists(env_file):\n    for ln in open(env_file, 'r', encoding='utf-8', errors='ignore'):\n        ln = ln.strip()\n        if not ln or ln.startswith('#') or '=' not in ln:\n            continue\n        k, v = ln.split('=', 1)\n        v = v.strip().strip('\"').strip(\"'\")\n        os.environ.setdefault(k.strip(), v)\n\nICLOUD_EMAIL = os.environ.get(\"ICLOUD_EMAIL\")\nICLOUD_APP_PASSWORD = os.environ.get(\"ICLOUD_APP_PASSWORD\")\nWORK_EMAIL = os.environ.get(\"WORK_EMAIL\", \"austin.king@parallon.com\")\n\nif not ICLOUD_EMAIL or not ICLOUD_APP_PASSWORD:\n    raise SystemExit(\"ICLOUD_EMAIL / ICLOUD_APP_PASSWORD missing\")\n\ndef dh(v):\n    if not v:\n        return \"\"\n    out = []\n    for part, enc in decode_header(v):\n        if isinstance(part, bytes):\n            out.append(part.decode(enc or \"utf-8\", errors=\"replace\"))\n        else:\n            out.append(part)\n    return \"\".join(out)\n\nmail = imaplib.IMAP4_SSL(\"imap.mail.me.com\", 993)\nmail.login(ICLOUD_EMAIL, ICLOUD_APP_PASSWORD)\nmail.select(\"INBOX\")\n\nsince = (datetime.utcnow() - timedelta(days=7)).strftime(\"%d-%b-%Y\")\nstatus, data = mail.search(None, f'(SINCE {since})')\nids = data[0].split() if status == \"OK\" and data and data[0] else []\n\nsenders = Counter()\nsubjects = []\nfor mid in ids[-120:]:\n    st, msg_data = mail.fetch(mid, \"(BODY.PEEK[HEADER.FIELDS (FROM SUBJECT DATE)])\")\n    if st != \"OK\" or not msg_data or not msg_data[0]:\n        continue\n    raw = msg_data[0][1]\n    m = email.message_from_bytes(raw)\n    frm = dh(m.get(\"From\", \"\"))\n    sub = dh(m.get(\"Subject\", \"(no subject)\"))\n    senders[frm] += 1\n    subjects.append(sub)\n\nmail.logout()"}],"details":{"status":"completed","exitCode":0,"durationMs":314,"aggregated":"#!/usr/bin/env python3\nimport os, imaplib, email\nfrom email.header import decode_header\nfrom datetime import datetime, timedelta\nfrom collections import Counter\nimport smtplib\nfrom email.message import EmailMessage\n\n# Optional env file loader (KEY='value' lines)\nenv_file = '/home/ec2-user/.openclaw/workspace/tools/icloud_mail.env'\nif os.path.exists(env_file):\n    for ln in open(env_file, 'r', encoding='utf-8', errors='ignore'):\n        ln = ln.strip()\n        if not ln or ln.startswith('#') or '=' not in ln:\n            continue\n        k, v = ln.split('=', 1)\n        v = v.strip().strip('\"').strip(\"'\")\n        os.environ.setdefault(k.strip(), v)\n\nICLOUD_EMAIL = os.environ.get(\"ICLOUD_EMAIL\")\nICLOUD_APP_PASSWORD = os.environ.get(\"ICLOUD_APP_PASSWORD\")\nWORK_EMAIL = os.environ.get(\"WORK_EMAIL\", \"austin.king@parallon.com\")\n\nif not ICLOUD_EMAIL or not ICLOUD_APP_PASSWORD:\n    raise SystemExit(\"ICLOUD_EMAIL / ICLOUD_APP_PASSWORD missing\")\n\ndef dh(v):\n    if not v:\n        return \"\"\n    out = []\n    for part, enc in decode_header(v):\n        if isinstance(part, bytes):\n            out.append(part.decode(enc or \"utf-8\", errors=\"replace\"))\n        else:\n            out.append(part)\n    return \"\".join(out)\n\nmail = imaplib.IMAP4_SSL(\"imap.mail.me.com\", 993)\nmail.login(ICLOUD_EMAIL, ICLOUD_APP_PASSWORD)\nmail.select(\"INBOX\")\n\nsince = (datetime.utcnow() - timedelta(days=7)).strftime(\"%d-%b-%Y\")\nstatus, data = mail.search(None, f'(SINCE {since})')\nids = data[0].split() if status == \"OK\" and data and data[0] else []\n\nsenders = Counter()\nsubjects = []\nfor mid in ids[-120:]:\n    st, msg_data = mail.fetch(mid, \"(BODY.PEEK[HEADER.FIELDS (FROM SUBJECT DATE)])\")\n    if st != \"OK\" or not msg_data or not msg_data[0]:\n        continue\n    raw = msg_data[0][1]\n    m = email.message_from_bytes(raw)\n    frm = dh(m.get(\"From\", \"\"))\n    sub = dh(m.get(\"Subject\", \"(no subject)\"))\n    senders[frm] += 1\n    subjects.append(sub)\n\nmail.logout()","cwd":"/home/ec2-user/.openclaw/workspace"},"isError":false,"timestamp":1772375664012}}
