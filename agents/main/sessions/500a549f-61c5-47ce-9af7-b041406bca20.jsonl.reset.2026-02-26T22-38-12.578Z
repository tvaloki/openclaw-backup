ir}/artifact_bundle\"\n  local report=\"${slug_dir}/findings_${slug}.md\"\n\n  mkdir -p \"${slug_dir}\"\n  echo \"#### Static Scan Findings (Red Flags)\" >> \"${report}\" 2>/dev/null || true\n  echo \"```bash\" >> \"${report}\"\n\n  if [ -d \"${bundle}\" ] && [ \"$(ls -A \"${bundle}\" 2>/dev/null)\" ]; then\n    # Build a find command for all code extensions, only if CODE_EXTENSIONS present\n    local ext_args=()\n    if [ ${#CODE_EXTENSIONS[@]} -gt 0 ]; then\n      for ext in \"${CODE_EXTENSIONS[@]}\"; do\n        ext_args+=( -iname \"*.${ext}\" )\n      done\n    fi\n\n    if [ ${#ext_args[@]} -gt 0 ]; then\n      # Grep for suspicious patterns across discovered files\n      if command -v find >/dev/null 2>&1 && command -v xargs >/dev/null 2>&1; then\n        find \"${bundle}\" -type f \\( ${ext_args[@]} \\) -print0 2>/dev/null | \\\n          xargs -0 grep -iEn --color=never \"${SUSPICIOUS_PATTERNS}\" 2>/dev/null > \"${slug_dir}/static_scan.log\" || true\n        if [ -s \"${slug_dir}/static_scan.log\" ]; then\n          cat \"${slug_dir}/static_scan.log\" >> \"${report}\"\n          echo \"\" >> \"${report}\"\n          echo \"--- SUSPICIOUS PATTERNS FOUND ---\" >> \"${report}\"\n          echo \"Review lines marked with suspicious patterns.\" >> \"${report}\"\n        else\n          echo \"✅ No obvious suspicious patterns found based on current search criteria.\" >> \"${report}\"\n        fi\n      else\n        echo \"WARNING: find/xargs not available; static scan skipped.\" >> \"${report}\"\n      fi\n    else\n      echo \"No CODE_EXTENSIONS defined; static analysis skipped.\" >> \"${report}\"\n    fi\n  else\n    echo \"Skill artifact bundle not found or empty. Skipping static analysis.\" >> \"${report}\"\n  fi\n\n  echo \"```\" >> \"${report}\"\n  echo \"\" >> \"${report}\"\n}\n\ndependencies_review() {\n  local slug=\"$1\"\n  local slug_dir=\"${INSPECTION_BASE_DIR}/${slug}\"\n  local bundle=\"${slug_dir}/artifact_bundle\"\n  local report=\"${slug_dir}/findings_${slug}.md\"\n\n  echo \"#### Dependency Review\" >> \"${report}\"\n  local had_any=false\n\n  if [ -f \"${bundle}/requirements.txt\" ]; then\n    echo \"Found requirements.txt\" >> \"${report}\"\n    echo \"```bash\" >> \"${report}\"\n    echo \"$(cat \"${bundle}/requirements.txt\")\" >> \"${report}\"\n    echo \"```\" >> \"${report}\"\n    had_any=true\n  fi\n\n  if [ -f \"${bundle}/package.json\" ]; then\n    echo \"Found package.json\" >> \"${report}\"\n    echo \"```bash\" >> \"${report}\"\n    if command -v npm >/dev/null 2>&1; then\n      (\n        cd \"${bundle}\"\n        if npm ci --ignore-scripts --silent --no-audit --prefer-offline 2>/dev/null; then\n          npm ls --json --production --omit=dev 2>/dev/null | sed 's/^/          /' | sed '$d' | cat >> \"${report}\"\n        else\n          echo \"{}\" >> \"${report}\"\n        fi\n      )\n    else\n      echo '{ \"dependencies\": {} }' >> \"${report}\"\n    fi\n    echo \"```\" >> \"${report}\"\n    had_any=true\n  fi\n\n  if [ \"${had_any}\" = false ]; then\n    echo \"✅ No common dependency manifest files (requirements.txt, package.json) found.\" >> \"${report}\"\n  fi\n  echo \"\" >> \"${report}\"\n}\n\nintegrity_checks() {\n  local slug=\"$1\"\n  local slug_dir=\"${INSPECTION_BASE_DIR}/${slug}\"\n  local bundle=\"${slug_dir}/artifact_bundle\"\n  local report=\"${slug_dir}/findings_${slug}.md\"\n\n  echo \"#### Integrity Checks (Hashing)\" >> \"${report}\"\n  if [ -d \"${bundle}\" ] && [ \"$(ls -A \"${bundle}\" 2>/dev/null)\" ]; then\n    if command -v sha256sum >/dev/null 2>&1; then\n      pushd \"${bundle}\" >/dev/null\n      sha256sum $(find . -type f -not -path \"./.git/*\" -print) 2>/dev/null | head -n 100 >> \"${report}\"\n      popd >/dev/null\n    else\n      echo \"sha256sum not available; skipping hashing.\" >> \"${report}\"\n    fi\n  else\n    echo \"No artifact bundle; skipping hashing.\" >> \"${report}\"\n  fi\n  echo \"\" >> \"${report}\"\n}\n\ngenerate_report() {\n  local slug=\"$1\"\n  local slug_dir=\"${INSPECTION_BASE_DIR}/${slug}\"\n  local report=\"${slug_dir}/findings_${slug}.md\"\n\n  if [ ! -f \"${report}\" ]; then\n    echo \"# Malware Vetting Report: \\`${slug}\\`\" > \"${report}\"\n    echo \"\" >> \"${report}\"\n  fi\n  echo \"\" >> \"${report}\"\n  echo \"Report generated by MV-VET script.\" >> \"${report}\"\n}\n\nverdict_for_slug() {\n  local slug=\"$1\"\n  local report=\"${INSPECTION_BASE_DIR}/${slug}/findings_${slug}.md\"\n  if [ ! -f \"${report}\" ]; then\n    echo \"${slug}: Safe\"\n    return 0\n  fi\n  if grep -qiE \"HIGH RISK|SUSPICIOUS PATTERNS FOUND|WARNING\" \"${report}\"; then\n    echo \"${slug}: Unsafe\"\n  else\n    echo \"${slug}: Safe\"\n  fi\n}\n\n# Main\nmain() {\n  check_prereqs\n\n  if [ \"$#\" -lt 1 ]; then\n    usage\n    exit 1\n  fi\n\n  local slug\n  for slug in \"$@\"; do\n    info \"Starting vet for ${slug}\"\n    inspect_slug \"${slug}\"\n    static_analysis \"${slug}\"\n    dependencies_review \"${slug}\"\n    integrity_checks \"${slug}\"\n    generate_report \"${slug}\"\n    info \"Completed vet for ${slug}. Findings at ${INSPECTION_BASE_DIR}/${slug}/findings_${slug}.md\"\n\n    verdict_for_slug \"${slug}\"\n  done\n}\n\nmain \"$@\""}}],"api":"openai-completions","provider":"openrouter","model":"openrouter/auto","usage":{"input":385,"output":3243,"cacheRead":31232,"cacheWrite":0,"totalTokens":34860,"cost":{"input":-385,"output":-3243,"cacheRead":0,"cacheWrite":0,"total":-3628}},"stopReason":"toolUse","timestamp":1772144406486}}
